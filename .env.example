# ConsignIQ Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose

# ─── Anthropic (AI Pricing Engine) ───────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── SerpApi (eBay Comp Lookups) ─────────────────────────────
# Found in: serpapi.com → Dashboard
SERPAPI_KEY=your-serpapi-key-here

# ─── Resend (Email — agreements, expiry notices) ─────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=noreply@consigniq.com

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://consigniq.com in prod
